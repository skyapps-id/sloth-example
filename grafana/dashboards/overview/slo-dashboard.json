{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Tier 1 - Critical (99.9%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "slo:sloth_example:tier1_availability:error_ratio:5m",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "unit": "percentunit",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Tier 1 Error Budget",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "1 - slo:sloth_example:tier1_availability:error_ratio:5m",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "title": "Tier 2 - Standard (99.5%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "slo:sloth_example:tier2_availability:error_ratio:5m",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.02 }
            ]
          },
          "unit": "percentunit",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Tier 3 - Background (99.0%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "slo:sloth_example:tier3_availability:error_ratio:5m",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.03 }
            ]
          },
          "unit": "percentunit",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Traefik Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "up{job=\"traefik\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Requests/sec by Tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{service=\"tier1-svc@file\"}[$__rate_interval])) by (code)",
          "legendFormat": "Tier 1 ({{code}})",
          "refId": "A"
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{service=\"tier2-svc@file\"}[$__rate_interval])) by (code)",
          "legendFormat": "Tier 2 ({{code}})",
          "refId": "B"
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{service=\"tier3-svc@file\"}[$__rate_interval])) by (code)",
          "legendFormat": "Tier 3 ({{code}})",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Error Rate by Tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{service=\"tier1-svc@file\",code=~\"5..\"}[$__rate_interval])) / sum(rate(traefik_service_requests_total{service=\"tier1-svc@file\"}[$__rate_interval])) * 100",
          "legendFormat": "Tier 1 Critical (target 0.1%)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{service=\"tier2-svc@file\",code=~\"5..\"}[$__rate_interval])) / sum(rate(traefik_service_requests_total{service=\"tier2-svc@file\"}[$__rate_interval])) * 100",
          "legendFormat": "Tier 2 Standard (target 0.5%)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{service=\"tier3-svc@file\",code=~\"5..\"}[$__rate_interval])) / sum(rate(traefik_service_requests_total{service=\"tier3-svc@file\"}[$__rate_interval])) * 100",
          "legendFormat": "Tier 3 Background (target 1%)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Latency p99 by Tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket{service=\"tier1-svc@file\"}[$__rate_interval])) by (le))",
          "legendFormat": "Tier 1 (target <500ms)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket{service=\"tier2-svc@file\"}[$__rate_interval])) by (le))",
          "legendFormat": "Tier 2 (target <1s)",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket{service=\"tier3-svc@file\"}[$__rate_interval])) by (le))",
          "legendFormat": "Tier 3 (target <5s)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Requests by Status Code",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(traefik_service_requests_total[1h])) by (code)",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "title": "SLO Burn Rate (Tier 1)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "slo:sloth_example:tier1_availability:burn_rate:5m",
          "legendFormat": "5m burn rate",
          "refId": "A"
        },
        {
          "expr": "slo:sloth_example:tier1_availability:burn_rate:30m",
          "legendFormat": "30m burn rate",
          "refId": "B"
        },
        {
          "expr": "slo:sloth_example:tier1_availability:burn_rate:6h",
          "legendFormat": "6h burn rate",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "title": "Open Connections by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "traefik_service_open_connections{service=\"tier1-svc@file\"}",
          "legendFormat": "Tier 1 (Critical)",
          "refId": "A"
        },
        {
          "expr": "traefik_service_open_connections{service=\"tier2-svc@file\"}",
          "legendFormat": "Tier 2 (Standard)",
          "refId": "B"
        },
        {
          "expr": "traefik_service_open_connections{service=\"tier3-svc@file\"}",
          "legendFormat": "Tier 3 (Background)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    }
  ],
  "schemaVersion": 38,
  "tags": ["slo", "monitoring", "tiers", "traefik"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SLO Tier Overview",
  "uid": "slo-tier-overview",
  "version": 1
}
