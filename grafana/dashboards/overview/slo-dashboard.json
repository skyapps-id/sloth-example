{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "SLO Error Ratio by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=~\"tier1-.*-availability\"}", "legendFormat": "{{sloth_slo}}", "refId": "A" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=~\"tier2-.*-availability\"}", "legendFormat": "{{sloth_slo}}", "refId": "B" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=~\"tier3-.*-availability\"}", "legendFormat": "{{sloth_slo}}", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "custom": { "fillOpacity": 20, "lineWidth": 2 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Error Budget Remaining by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:period_error_budget_remaining:ratio{sloth_slo=~\"tier1-.*-availability\"}", "legendFormat": "{{sloth_slo}}", "refId": "A" },
        { "expr": "slo:period_error_budget_remaining:ratio{sloth_slo=~\"tier2-.*-availability\"}", "legendFormat": "{{sloth_slo}}", "refId": "B" },
        { "expr": "slo:period_error_budget_remaining:ratio{sloth_slo=~\"tier3-.*-availability\"}", "legendFormat": "{{sloth_slo}}", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 20, "lineWidth": 2 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Burn Rate (Tier 1)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:current_burn_rate:ratio{sloth_slo=~\"tier1-.*-availability\"}", "legendFormat": "{{sloth_slo}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Tier 1 - Critical Endpoints",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier1-login-availability\"}", "legendFormat": "/login", "refId": "A" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier1-payment-availability\"}", "legendFormat": "/api/payment", "refId": "B" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier1-checkout-availability\"}", "legendFormat": "/api/checkout", "refId": "C" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier1-auth-availability\"}", "legendFormat": "/api/auth/*", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.001 }, { "color": "red", "value": 0.01 }] },
          "unit": "percentunit",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "displayMode": "gradient" }
    },
    {
      "title": "Tier 2 - Standard Endpoints",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier2-users-availability\"}", "legendFormat": "/api/users", "refId": "A" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier2-products-availability\"}", "legendFormat": "/api/products", "refId": "B" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier2-orders-availability\"}", "legendFormat": "/api/orders", "refId": "C" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier2-cart-availability\"}", "legendFormat": "/api/cart", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.005 }, { "color": "red", "value": 0.02 }] },
          "unit": "percentunit",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "displayMode": "gradient" }
    },
    {
      "title": "Tier 3 - Background Endpoints",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier3-reports-availability\"}", "legendFormat": "/api/reports", "refId": "A" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier3-analytics-availability\"}", "legendFormat": "/api/analytics", "refId": "B" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier3-notifications-availability\"}", "legendFormat": "/api/notifications", "refId": "C" },
        { "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"tier3-exports-availability\"}", "legendFormat": "/api/exports", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.03 }] },
          "unit": "percentunit",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "displayMode": "gradient" }
    },
    {
      "title": "Traefik / App Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "up{job=\"traefik\"}", "legendFormat": "Traefik", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background" }
    },
    {
      "title": "Raw Error Rate per Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(traefik_service_requests_total{code=~\"5..\"}[$__rate_interval])) by (service) * 100", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "custom": { "fillOpacity": 20, "lineWidth": 2 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Latency p99 per Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket[$__rate_interval])) by (le, service))", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Requests by Status Code",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(traefik_service_requests_total[1h])) by (code)", "legendFormat": "{{code}}", "refId": "A" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "pieType": "donut" }
    },
    {
      "title": "Requests per Endpoint",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(traefik_service_requests_total[1h])) by (service)", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "orientation": "horizontal" }
    }
  ],
  "schemaVersion": 38,
  "tags": ["slo", "monitoring", "tiers", "traefik", "per-endpoint"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SLO Per-Endpoint Overview",
  "uid": "slo-tier-overview",
  "version": 3
}
